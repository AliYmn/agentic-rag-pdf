# Copy this file to .env and fill in the value:  cp .env.example .env

# --- LLM + Embeddings (single provider: OpenAI) ---
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Chat model for the agent (orchestrator + verifier). Needs tools + vision.
OPENAI_MODEL=gpt-4o
# Embedding model for dense retrieval.
EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval tuning ---
# Default number of fused passages returned by the search tool
RETRIEVAL_TOP_K=8
# Reciprocal-Rank-Fusion constant
RRF_K=60

# --- Memory (cross-task learning) ---
MEMORY_PATH=./data/memory.jsonl
