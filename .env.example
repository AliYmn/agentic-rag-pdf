# Copy this file to .env and fill in the values.

# --- LLM / Anthropic ---
ANTHROPIC_API_KEY=
# Default model for the agent (see https://docs.anthropic.com)
ANTHROPIC_MODEL=claude-opus-4-8

# --- Embeddings / Vector store ---
EMBEDDING_MODEL=
VECTOR_DB_PATH=./data/vector_store

# --- App ---
LOG_LEVEL=INFO
